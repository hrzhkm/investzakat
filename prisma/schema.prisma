generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())
}

model goldData {
  id         Int      @id @default(autoincrement())
  asset      String   @default("XAUT")
  currency   String   @default("MYR")
  priceMyr   Float
  rawData    Json
  fetchedAt  DateTime @default(now())
  createdAt  DateTime @default(now())
}
